# Root .gitignore for Phishing Detector Mono-repo

# Java (Backend)
backend/target/
backend/*.jar
backend/*.war
backend/*.ear
backend/.mvn/wrapper/maven-wrapper.jar
backend/build_log.txt
backend/compile_output.txt
backend/server_run_*.txt

# Node (Frontend)
frontend/node_modules/
frontend/dist/
frontend/dist-ssr/
frontend/*.local

# Python (ML Service)
ml-service/__pycache__/
ml-service/*.py[cod]
ml-service/*$py.class
ml-service/.venv
ml-service/venv
ml-service/env/
ml-service/.env

# IDE / System
.idea/
.vscode/
*.swp
*.swo
.DS_Store
*.log
